{
  "name": "@skill-set/cli",
  "version": "0.4.0",
  "description": "Define, share, and install named, versioned sets of agent skills.",
  "type": "module",
  "bin": {
    "skill-set": "bin/cli.mjs"
  },
  "files": [
    "bin",
    "dist",
    "schema"
  ],
  "keywords": [
    "agent",
    "skills",
    "agent-skills",
    "skill-set",
    "ai",
    "cli"
  ],
  "author": "Harry Martin <hcjmartin@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hcjmartin/skill-set.git",
    "directory": "packages/cli"
  },
  "homepage": "https://skill-set.md",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "prepack": "node scripts/sync-schemas.mjs",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "ci-info": "^4.4.0",
    "tinyexec": "^1.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
