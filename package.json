{
  "name": "skill-set",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "check": "pnpm run build && pnpm run typecheck && pnpm run lint && pnpm run test",
    "coverage": "pnpm --filter @skill-set/cli run test:coverage"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.39.4",
    "eslint": "^10.5.0",
    "typescript-eslint": "^8.62.0"
  }
}
