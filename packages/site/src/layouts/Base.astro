---
import '@fontsource-variable/instrument-sans'
import '@fontsource-variable/jetbrains-mono'

interface Props {
  title: string
  description: string
}
const { title, description } = Astro.props
const nav = [
  { href: '/cli/', label: 'CLI' },
  { href: '/spec/', label: 'Spec' },
  { href: '/faq/', label: 'FAQ' },
]
const path = Astro.url.pathname
const canonical = new URL(path, Astro.site)
const fullTitle = title === 'skill-set' ? title : `${title} — skill-set`
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="skill-set" />
    <meta name="twitter:card" content="summary" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#ffffff" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#101418" />
  </head>
  <body>
    <header>
      <div class="shell">
        <a class="wordmark" href="/"
          ><span class="brace">{'{'}</span>skill-set<span class="brace">{'}'}</span><span class="sub">spec</span></a
        >
        <nav>
          {nav.map((item) => <a href={item.href} aria-current={path.startsWith(item.href) ? 'page' : undefined}>{item.label}</a>)}
          <a class="ghost" href="https://github.com/hcjmartin/skill-set">GitHub</a>
        </nav>
      </div>
    </header>
    <main class="shell">
      <slot />
    </main>
    <footer>
      <div class="shell">
        <p>
          MIT license. Built by <a href="https://github.com/hcjmartin">Harry Martin</a>.
        </p>
        <p>
          Schemas:
          <a href="/schema/draft/skill-set.schema.json">manifest</a>,
          <a href="/schema/draft/skill-set.lock.schema.json">set-lock</a>.
        </p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    /* Shared with skill-sets.md: typefaces and brand accent tie the two sites
       together; the spec keeps its own restrained, dark-mode-capable palette. */
    --font-sans: 'Instrument Sans Variable', ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Helvetica, Arial, sans-serif;
    --font-mono: 'JetBrains Mono Variable', ui-monospace, 'SF Mono', SFMono-Regular, Menlo, Consolas, monospace;
    --accent: #ff5733;

    --bg: #ffffff;
    --fg: #1d2329;
    --muted: #5b6570;
    --line: #e4e8ec;
    --link: #0b57c2;
    --code-bg: #0d1117;
    --code-fg: #e6edf3;
    --inline-code-bg: #eef1f4;
    --note-bg: #f6f8fa;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --accent: #ff6b4a;
      --bg: #101418;
      --fg: #e4e8ec;
      --muted: #9aa4ad;
      --line: #262d34;
      --link: #6ca8f2;
      --inline-code-bg: #1c2229;
      --note-bg: #171c22;
    }
  }

  * {
    box-sizing: border-box;
  }
  html {
    background: var(--bg);
    color: var(--fg);
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.65;
    -webkit-text-size-adjust: 100%;
  }
  body {
    margin: 0;
    display: flex;
    min-height: 100vh;
    flex-direction: column;
  }
  .shell {
    width: 100%;
    max-width: 880px;
    margin: 0 auto;
    /* padding-inline (not the `padding` shorthand) so it never zeroes the
       vertical padding that header/main/footer set — matches skill-sets.md. */
    padding-inline: 28px;
  }

  header {
    border-bottom: 1px solid var(--line);
  }
  header .shell {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1rem;
    padding-bottom: 1rem;
  }
  .wordmark {
    font-weight: 600;
    color: var(--fg);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    white-space: nowrap;
  }
  .wordmark .brace {
    color: var(--accent);
  }
  .wordmark .sub {
    margin-left: 0.4em;
    font-size: 0.8em;
    font-weight: 500;
    color: var(--muted);
  }
  header nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }
  header nav a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.84rem;
  }
  header nav a:hover,
  header nav a[aria-current='page'] {
    color: var(--fg);
  }
  header nav a.ghost {
    color: var(--fg);
    border: 1px solid color-mix(in srgb, var(--fg) 20%, transparent);
    border-radius: 6px;
    padding: 5px 12px;
  }
  header nav a.ghost:hover {
    border-color: var(--fg);
  }

  main {
    flex: 1;
    padding-top: 52px;
    padding-bottom: 64px;
  }

  footer {
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.85rem;
  }
  footer .shell {
    padding-top: 1.1rem;
    padding-bottom: 1.4rem;
  }
  footer p {
    margin: 0.2rem 0;
  }
  footer a {
    color: var(--muted);
  }

  a {
    color: var(--link);
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  h1 {
    font-size: 1.7rem;
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin: 0 0 0.75rem;
  }
  h2 {
    font-size: 1.22rem;
    line-height: 1.35;
    margin: 2.4rem 0 0.6rem;
  }
  h3 {
    font-size: 1.02rem;
    margin: 1.8rem 0 0.5rem;
  }
  h2 .anchor,
  h3 .anchor {
    margin-left: 0.4em;
    color: var(--muted);
    text-decoration: none;
    opacity: 0;
  }
  h2:hover .anchor,
  h3:hover .anchor,
  .anchor:focus {
    opacity: 0.8;
  }

  p,
  ul,
  ol {
    margin: 0.75rem 0;
  }
  li {
    margin: 0.25rem 0;
  }
  hr {
    border: 0;
    border-top: 1px solid var(--line);
    margin: 2.5rem 0;
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.86em;
  }
  :not(pre) > code {
    background: var(--inline-code-bg);
    border-radius: 4px;
    padding: 0.12em 0.35em;
  }
  pre {
    background: var(--code-bg);
    color: var(--code-fg);
    border-radius: 8px;
    padding: 0.9rem 1.1rem;
    overflow-x: auto;
    font-size: 0.86rem;
    line-height: 1.55;
    margin: 1rem 0;
  }
  pre.astro-code {
    background: var(--code-bg) !important;
  }
  pre code {
    font-size: 1em;
    background: none;
    padding: 0;
  }

  table {
    display: block;
    width: fit-content;
    max-width: 100%;
    overflow-x: auto;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.9rem;
  }
  th,
  td {
    border: 1px solid var(--line);
    padding: 0.4rem 0.7rem;
    text-align: left;
    vertical-align: top;
  }
  th {
    background: var(--note-bg);
  }

  blockquote {
    margin: 1rem 0;
    padding: 0.1rem 1rem;
    border-left: 3px solid var(--line);
    background: var(--note-bg);
    color: var(--muted);
    border-radius: 0 6px 6px 0;
  }

  .lede {
    color: var(--muted);
    font-size: 1.05rem;
    margin-top: 0;
  }
  .note {
    background: var(--note-bg);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 0.7rem 1rem;
    font-size: 0.9rem;
    color: var(--muted);
  }
  .toc {
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 0.9rem 1.2rem;
    margin: 1.5rem 0 2rem;
    font-size: 0.92rem;
  }
  .toc h2 {
    margin: 0 0 0.4rem;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
  }
  .toc ol {
    margin: 0;
    padding-left: 1.2rem;
  }
  .toc a {
    text-decoration: none;
  }
  .toc a:hover {
    text-decoration: underline;
  }
</style>
